{
  "rewrites": [
    { "source": "/developer/:slug", "destination": "/api/ssr" },
    { "source": "/cases", "destination": "/api/ssr" },
    { "source": "/about", "destination": "/api/ssr" },
    { "source": "/privacy", "destination": "/api/ssr" },
    { "source": "/audit", "destination": "/api/ssr" },
    { "source": "/submit", "destination": "/api/ssr" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ]
}
